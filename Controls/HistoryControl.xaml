<UserControl
    x:Class="ConversionApp.Controls.HistoryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ConversionApp.Models"
    xmlns:converters="using:ConversionApp.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:DateTimeToRelativeConverter x:Key="DateTimeToRelativeConverter"/>
    </UserControl.Resources>

    <StackPanel Spacing="16" Margin="0,16,0,0">
        <TextBlock Text="Recent Activity" 
                   Style="{StaticResource SubtitleTextBlockStyle}" 
                   FontWeight="SemiBold"
                   Visibility="{x:Bind HistoryItems.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}"/>
        
        <ListView ItemsSource="{x:Bind HistoryItems, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="ListView_ItemClick"
                  MaxWidth="600"
                  HorizontalAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConversionHistoryItem">
                    <Grid Padding="12,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}" 
                                CornerRadius="8" 
                                Width="40" Height="40" 
                                VerticalAlignment="Center">
                            <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="20"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ConversionType}" 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{x:Bind Timestamp, Converter={StaticResource DateTimeToRelativeConverter}}" 
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                    <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </StackPanel>
</UserControl>
