<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Eezy Pro"
           Manufacturer="Eezy Pro"
           Version="1.0.0.0"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Codepage="1252"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Eezy Pro is already installed." />

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Install to C:\Program Files\Eezy Pro -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="Eezy Pro" />
    </StandardDirectory>

    <!-- Start Menu group -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Eezy Pro" />
    </StandardDirectory>

    <!-- Desktop -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Feature references the harvested component group + shortcuts -->
    <Feature Id="ProductFeature" Title="Eezy Pro" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcuts" />
    </Feature>

    <!-- Shortcuts + uninstall entry -->
    <Component Id="AppShortcuts" Directory="ApplicationProgramsFolder" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
      <Shortcut Id="StartMenuShortcut"
                Name="Eezy Pro"
                Description="Eezy Pro - Document Conversion Suite"
                Target="[INSTALLFOLDER]ConversionApp.exe"
                WorkingDirectory="INSTALLFOLDER" />

      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="Eezy Pro"
                Description="Eezy Pro - Document Conversion Suite"
                Target="[INSTALLFOLDER]ConversionApp.exe"
                WorkingDirectory="INSTALLFOLDER" />

      <Shortcut Id="UninstallShortcut"
                Name="Uninstall Eezy Pro"
                Target="[SystemFolder]msiexec.exe"
                Arguments="/x [ProductCode]" />

      <RegistryValue Root="HKCU"
                     Key="Software\EezyPro"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />

      <RemoveFolder Id="CleanupStartMenu" Directory="ApplicationProgramsFolder" On="uninstall" />
    </Component>

  </Package>
</Wix>
