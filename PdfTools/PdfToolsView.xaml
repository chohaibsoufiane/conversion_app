<UserControl
    x:Class="ConversionApp.PdfTools.PdfToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ConversionApp.PdfTools">

    <Grid Padding="32,28,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Separator -->
            <RowDefinition Height="*"/>      <!-- Tool grid -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="PDF Tools"
                       Style="{StaticResource TitleTextBlockStyle}"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Select a tool to get started"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Opacity="0.8"/>
        </StackPanel>

        <!-- Thin divider -->
        <Border Grid.Row="1"
                Height="1"
                Margin="0,16,0,20"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                Opacity="0.4"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Empty state — shown when no tools are registered           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <FontIcon Glyph="&#xE8A5;"
                      FontSize="48"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="No tools registered yet"
                       HorizontalAlignment="Center"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="Tools will appear here once registered with ToolRegistry."
                       HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TOOL CARD GRID                                             -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ToolScrollViewer"
                      Grid.Row="2"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="ToolCardsRepeater">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="220"
                                       MinItemHeight="180"
                                       MinRowSpacing="16"
                                       MinColumnSpacing="16"
                                       ItemsStretch="None"
                                       ItemsJustification="Center"/>
                </ItemsRepeater.Layout>

                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:ToolCardViewModel">
                        <Button HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Padding="20"
                                CornerRadius="10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Click="ToolCard_Click"
                                Tag="{x:Bind ToolName}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Tool icon -->
                                    <FontIcon Grid.Row="0"
                                              Glyph="{x:Bind IconGlyph}"
                                              FontSize="28"
                                              HorizontalAlignment="Left"
                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                    <!-- Name + description -->
                                    <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="4">
                                        <TextBlock Text="{x:Bind ToolName}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind ToolDescription}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="3"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Chevron -->
                                    <FontIcon Grid.Row="2"
                                              Glyph="&#xE76C;"
                                              FontSize="12"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Bottom"
                                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                              Margin="0,8,0,0"/>
                                </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
