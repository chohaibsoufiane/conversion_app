<UserControl
    x:Class="ConversionApp.PdfTools.ConversionDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ConversionApp.PdfTools"
    xmlns:vm="using:ConversionApp.ViewModels">

    <Grid>
        <!-- Navigation -->
        <Button Click="BackButton_Click"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="20,20,0,0"
                Background="Transparent"
                BorderThickness="0"
                ToolTipService.ToolTip="Back to PDF Tools">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                <TextBlock Text="Back"/>
            </StackPanel>
        </Button>

        <!-- Selection Phase -->
        <Grid x:Name="FileSelectionPhase" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="28" HorizontalAlignment="Center" MaxWidth="640" Padding="40">
                
                <!-- Header with Title and Swap Button -->
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.ActiveToolTitle, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}"/>
                    <Button Command="{x:Bind ViewModel.SwapDirectionCommand}"
                            Padding="8" 
                            CornerRadius="20" 
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Swap Direction">
                        <FontIcon Glyph="&#xE8AB;" FontSize="18"/>
                    </Button>
                </StackPanel>
                
                <Grid x:Name="DropZone" AllowDrop="True" DragOver="DropZone_DragOver" DragLeave="DropZone_DragLeave" Drop="DropZone_Drop" MinWidth="520" MinHeight="220">
                    <!-- Dashed Outline -->
                    <Rectangle Stroke="{ThemeResource AccentFillColorDefaultBrush}" 
                               StrokeThickness="2" 
                               StrokeDashArray="4 2" 
                               RadiusX="16" RadiusY="16"
                               Fill="{ThemeResource AccentFillColorTertiaryBrush}"
                               Opacity="0.1"/>
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <FontIcon Glyph="&#xE8E5;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center"/>
                        <Button Click="ChooseFileButton_Click" HorizontalAlignment="Center" Padding="24,10" Style="{StaticResource AccentButtonStyle}">
                            <TextBlock Text="CHOOSE FILE" FontWeight="SemiBold"/>
                        </Button>
                        <TextBlock Text="or drop a file here" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Converting Phase -->
        <Grid x:Name="ConvertingPhase" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="24" HorizontalAlignment="Center" MaxWidth="640" Padding="40">
                
                <!-- Header with Title and Swap Button -->
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.ActiveToolTitle, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}"/>
                    <Button Command="{x:Bind ViewModel.SwapDirectionCommand}"
                            Padding="8" 
                            CornerRadius="20" 
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Swap Direction">
                        <FontIcon Glyph="&#xE8AB;" FontSize="18"/>
                    </Button>
                </StackPanel>
                
                <!-- File Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="20,16" MinWidth="480">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE8A5;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="SelectedFileName" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SelectedFileSize" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Click="RemoveFile_Click" Background="Transparent" BorderThickness="0"><FontIcon Glyph="&#xE711;"/></Button>
                    </Grid>
                </Border>

                <!-- Convert Button -->
                <Button Style="{StaticResource AccentButtonStyle}" 
                        Command="{x:Bind ViewModel.ConvertCommand}" 
                        HorizontalAlignment="Stretch" Padding="0,14" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="Convert" FontWeight="SemiBold"/>
                        <ProgressRing IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}" Width="20" Height="20"/>
                    </StackPanel>
                </Button>

                <!-- Status Card -->
                <Border Visibility="{x:Bind BoolToVis(ViewModel.IsStatusVisible), Mode=OneWay}" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE73E;" Foreground="#4CAF50" Visibility="{x:Bind BoolToVis(ViewModel.IsSuccess), Mode=OneWay}"/>
                        <FontIcon Glyph="&#xEA39;" Foreground="#F44336" Visibility="{x:Bind BoolToVis(ViewModel.IsError), Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
