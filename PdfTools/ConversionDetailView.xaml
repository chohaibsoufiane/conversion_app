<UserControl
    x:Class="ConversionApp.PdfTools.ConversionDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ConversionApp.PdfTools"
    xmlns:vm="using:ConversionApp.ViewModels">

    <UserControl.Resources>
        <Storyboard x:Name="SwapAnimation">
            <DoubleAnimation Storyboard.TargetName="SwapIconTransform"
                             Storyboard.TargetProperty="Rotation"
                             By="180" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.5" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SourceText"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.4" Duration="0:0:0.2" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="TargetText"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.4" Duration="0:0:0.2" AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Navigation -->
        <Button Click="BackButton_Click"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="20,20,0,0"
                Background="Transparent"
                BorderThickness="0"
                ToolTipService.ToolTip="Back to PDF Tools"
                Canvas.ZIndex="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                <TextBlock Text="Back"/>
            </StackPanel>
        </Button>

        <ScrollViewer>
            <StackPanel Padding="0,80,0,40" Spacing="48">
                
                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- HEADER WITH STABLE SWAP BUTTON                              -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" 
                           Width="64" Height="64"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Source="{x:Bind ViewModel.SourceIconPath, Mode=OneWay}"/>
                    
                    <FontIcon Grid.Column="1" 
                              Glyph="&#xE72A;" 
                              FontSize="24" 
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Margin="40,0"/>

                    <Image Grid.Column="2" 
                           Width="64" Height="64"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Source="{x:Bind ViewModel.TargetIconPath, Mode=OneWay}"/>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- SELECTION PHASE (The Accented Zone)                         -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Grid x:Name="FileSelectionPhase" HorizontalAlignment="Center" Width="800">
                    <Grid x:Name="DropZone" 
                          AllowDrop="True" 
                          DragOver="DropZone_DragOver" 
                          DragLeave="DropZone_DragLeave" 
                          Drop="DropZone_Drop" 
                          Height="280">
                        
                        <!-- Main Background -->
                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="12">
                            <!-- Inset Dashed Outline -->
                            <Rectangle Margin="10"
                                       Stroke="White" 
                                       StrokeThickness="1" 
                                       StrokeDashArray="4 2" 
                                       RadiusX="8" RadiusY="8"
                                       Opacity="0.3"/>
                        </Border>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="28">
                            <!-- Choose Files Button (Fixed Split Style) -->
                            <Border CornerRadius="8" Background="White" HorizontalAlignment="Center" BorderThickness="0">
                                <Grid Height="64">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" 
                                            Click="ChooseFileButton_Click" 
                                            Padding="40,0" 
                                            Background="Transparent" 
                                            Foreground="Black" 
                                            BorderThickness="0"
                                            VerticalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="22"/>
                                            <TextBlock Text="CHOOSE FILES" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Border Grid.Column="1" Background="#EEE" VerticalAlignment="Stretch" Margin="0,12"/>
                                    
                                    <Button Grid.Column="2" 
                                            Padding="20,0" 
                                            Background="Transparent" 
                                            Foreground="Black" 
                                            BorderThickness="0"
                                            VerticalAlignment="Stretch">
                                        <FontIcon Glyph="&#xE70D;" FontSize="18" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Text="or drop files here" 
                                       Foreground="White" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- CONVERTING PHASE                                            -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Grid x:Name="ConvertingPhase" Visibility="Collapsed" HorizontalAlignment="Center" Width="800">
                    <StackPanel Spacing="24">
                        <!-- File Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="12" Padding="24,20">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <FontIcon Glyph="&#xE8A5;" FontSize="40" Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock x:Name="SelectedFileName" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="SelectedFileSize" Style="{StaticResource CaptionTextBlockStyle}" FontSize="14"/>
                                </StackPanel>
                                
                                <Button Grid.Column="2" Click="RemoveFile_Click" Background="Transparent" BorderThickness="0" Padding="12">
                                    <FontIcon Glyph="&#xE711;" FontSize="20"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Big Convert Button -->
                        <Button Style="{StaticResource AccentButtonStyle}" 
                                Command="{x:Bind ViewModel.ConvertCommand}" 
                                HorizontalAlignment="Stretch" 
                                Padding="0,20" 
                                CornerRadius="12"
                                BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                                <TextBlock Text="CONVERT NOW" FontSize="20" FontWeight="Bold"/>
                                <ProgressRing IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}" Width="24" Height="24" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Status Card -->
                        <Border Visibility="{x:Bind BoolToVis(ViewModel.IsStatusVisible), Mode=OneWay}" 
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE73E;" Foreground="#4CAF50" FontSize="24" Visibility="{x:Bind BoolToVis(ViewModel.IsSuccess), Mode=OneWay}"/>
                                    <FontIcon Glyph="&#xEA39;" Foreground="#F44336" FontSize="24" Visibility="{x:Bind BoolToVis(ViewModel.IsError), Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontSize="16" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Visibility="{x:Bind BoolToVis(ViewModel.IsSuccess), Mode=OneWay}">
                                    <Button Content="Open File" Command="{x:Bind ViewModel.OpenOutputCommand}" Style="{StaticResource DefaultButtonStyle}" />
                                    <Button Content="Open Folder" Command="{x:Bind ViewModel.OpenOutputFolderCommand}" Style="{StaticResource AccentButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
