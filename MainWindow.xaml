<Window
    x:Class="ConversionApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pdf="using:ConversionApp.PdfTools"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" 
              Height="32" 
              VerticalAlignment="Top">
            <TextBlock Text="Batch Document Converter" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="Left"
                        IsPaneOpen="False"
                        ItemInvoked="NavView_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Document" Content="Conversion" Tag="Home"/>
                <NavigationViewItem Tag="PdfTools" Content="PDF Tools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA90;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!-- Home View -->
                <Grid x:Name="HomeView" 
                      Padding="32,28,32,32"
                      MaxWidth="960"
                      HorizontalAlignment="Center"
                      RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Batch Document Converter"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Convert .docx files to structured Block Editor JSON"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.8"/>
                    </StackPanel>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="Input Folder"
                                 PlaceholderText="Select a folder containing .docx files..."
                                 Text="{x:Bind ViewModel.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 VerticalAlignment="Bottom"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{x:Bind ViewModel.SelectInputFolderCommand}"
                                VerticalAlignment="Bottom"
                                MinWidth="100"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="Output Folder"
                                 PlaceholderText="Select a destination folder for JSON output..."
                                 Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 VerticalAlignment="Bottom"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                VerticalAlignment="Bottom"
                                MinWidth="100"/>
                    </Grid>

                    <Button Grid.Row="3"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StartConversionCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="0,12">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="Start Batch Conversion" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                                          Width="20" Height="20"
                                          VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Row="4"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontStyle="Italic"/>

                    <Border Grid.Row="5"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            Padding="0">
                        <ListView x:Name="LogListView"
                                  ItemsSource="{x:Bind ViewModel.LogMessages, Mode=OneWay}"
                                  SelectionMode="None"
                                  FlowDirection="{x:Bind ViewModel.LogFlowDirection, Mode=OneWay}"
                                  FontFamily="Cascadia Mono, Consolas, Courier New"
                                  FontSize="13"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  Padding="16,12">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="20"/>
                                    <Setter Property="Padding" Value="0,2"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>

                <!-- Settings View -->
                <Grid x:Name="SettingsView" Visibility="Collapsed" Padding="32,28,32,32" MaxWidth="960" HorizontalAlignment="Left">
                    <StackPanel Spacing="24">
                        <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Window Effect" FontWeight="SemiBold"/>
                                        <TextBlock Text="Adjust the translucency level of the application background." 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="BackdropComboBox" 
                                              Grid.Column="1"
                                              Width="200"
                                              VerticalAlignment="Center"
                                              SelectedIndex="1"
                                              SelectionChanged="BackdropComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Mica (Default)"/>
                                        <ComboBoxItem Content="Mica (Alt - High Tint)"/>
                                        <ComboBoxItem Content="Acrylic (Glassy)"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- PDF Tools View -->
                <pdf:PdfToolsView x:Name="PdfToolsView"
                                  Visibility="Collapsed"
                                  ToolRequested="PdfToolsView_ToolRequested"/>

                <!-- Word-to-PDF Detail View -->
                <pdf:WordToPdfDetailView x:Name="WordToPdfDetailView"
                                         Visibility="Collapsed"
                                         BackRequested="WordToPdfDetailView_BackRequested"/>

                <!-- Excel-to-PDF Detail View -->
                <pdf:ExcelToPdfDetailView x:Name="ExcelToPdfDetailView"
                                          Visibility="Collapsed"
                                          BackRequested="ExcelToPdfDetailView_BackRequested"/>

                <!-- PDF-to-Word Detail View -->
                <pdf:PdfToWordDetailView x:Name="PdfToWordDetailView"
                                         Visibility="Collapsed"
                                         BackRequested="PdfToWordDetailView_BackRequested"/>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
