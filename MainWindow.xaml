<Window
    x:Class="ConversionApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pdf="using:ConversionApp.PdfTools"
    xmlns:converters="using:ConversionApp.Converters"
    xmlns:models="using:ConversionApp.Models"
    xmlns:controls="using:ConversionApp.Controls"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.Resources>
            <!-- Splash animation -->
            <Storyboard x:Key="SplashStoryboard" x:Name="SplashStoryboard" Completed="SplashStoryboard_Completed">
                <DoubleAnimation Storyboard.TargetName="SplashOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.0" Duration="0:0:0.5"
                                 BeginTime="0:0:2.0" />
                <DoubleAnimation Storyboard.TargetName="SplashLogo"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0" Duration="0:0:1.0">
                    <DoubleAnimation.EasingFunction>
                        <ExponentialEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="SplashLogoTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="20" To="0" Duration="0:0:1.0">
                    <DoubleAnimation.EasingFunction>
                        <ExponentialEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Overlay to control Mica intensity (0 = max mica, 1 = solid background) -->
        <Border x:Name="MicaOverlay" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0" Grid.RowSpan="2"/>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" 
              Height="32" 
              VerticalAlignment="Top">
            <TextBlock Text="Eezy Pro" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="Left"
                        IsPaneOpen="False"
                        ItemInvoked="NavView_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Home" Tag="Dashboard"/>
                <NavigationViewItem Icon="Document" Content="Batch Conversion" Tag="BatchConverter"/>
                <NavigationViewItem Tag="PdfTools" Content="PDF Tools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA90;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!-- Dashboard View -->
                <Grid x:Name="DashboardView" 
                      Padding="32,28,32,32"
                      MaxWidth="960"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <CompositeTransform x:Name="DashboardTransform"/>
                    </Grid.RenderTransform>
                    <StackPanel Spacing="32" HorizontalAlignment="Center">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Welcome to Eezy Pro"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a tool from the menu to get started."
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <Grid ColumnSpacing="24" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Tag="BatchConverter" Click="DashboardCard_Click" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Padding="24" Spacing="16" Width="280">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="48" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Batch Conversion" FontWeight="SemiBold" FontSize="20"/>
                                    <TextBlock Text="Convert .docx files to structured JSON quickly and reliably." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Tag="PdfTools" Click="DashboardCard_Click" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Padding="24" Spacing="16" Width="280">
                                    <FontIcon Glyph="&#xEA90;" FontSize="48" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="PDF Tools" FontWeight="SemiBold" FontSize="20"/>
                                    <TextBlock Text="Convert PDF to Word, Excel to PDF, and more with high fidelity." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- History Section -->
                        <controls:HistoryControl HistoryItems="{x:Bind ViewModel.HistoryItems, Mode=OneWay}"
                                                 ItemClick="HistoryControl_ItemClick"
                                                 Margin="0,16,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Batch Converter View -->
                <Grid x:Name="BatchConverterView" Visibility="Collapsed"
                      Padding="32,28,32,32"
                      MaxWidth="960"
                      HorizontalAlignment="Center"
                      RowSpacing="20"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <CompositeTransform x:Name="BatchConverterTransform"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Batch Document Converter"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Convert .docx files to structured Block Editor JSON"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.8"/>
                    </StackPanel>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="Input Folder"
                                 PlaceholderText="Select a folder containing .docx files..."
                                 Text="{x:Bind ViewModel.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 VerticalAlignment="Bottom"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{x:Bind ViewModel.SelectInputFolderCommand}"
                                VerticalAlignment="Bottom"
                                MinWidth="100"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="Output Folder"
                                 PlaceholderText="Select a destination folder for JSON output..."
                                 Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 VerticalAlignment="Bottom"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                VerticalAlignment="Bottom"
                                MinWidth="100"/>
                    </Grid>

                    <Button Grid.Row="3"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StartConversionCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="0,12">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="Start Batch Conversion" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                                          Width="20" Height="20"
                                          VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Row="4"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontStyle="Italic"/>

                    <Border Grid.Row="5"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            Padding="0">
                        <ListView x:Name="LogListView"
                                  ItemsSource="{x:Bind ViewModel.LogMessages, Mode=OneWay}"
                                  SelectionMode="None"
                                  FlowDirection="{x:Bind ViewModel.LogFlowDirection, Mode=OneWay}"
                                  FontFamily="Cascadia Mono, Consolas, Courier New"
                                  FontSize="13"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  Padding="16,12">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="20"/>
                                    <Setter Property="Padding" Value="0,2"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>

                <!-- Settings View -->
                <Grid x:Name="SettingsView" Visibility="Collapsed" Padding="32,28,32,32" MaxWidth="960" HorizontalAlignment="Left"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <CompositeTransform x:Name="SettingsTransform"/>
                    </Grid.RenderTransform>
                    <StackPanel Spacing="24">
                        <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Window Effect" FontWeight="SemiBold"/>
                                        <TextBlock Text="Adjust the translucency level of the application background." 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </StackPanel>
                                    <Slider x:Name="BackdropSlider" 
                                              Grid.Column="1"
                                              Width="200"
                                              VerticalAlignment="Center"
                                              Minimum="0"
                                              Maximum="3"
                                              Value="2"
                                              StepFrequency="1"
                                              TickFrequency="1"
                                              SnapsTo="Ticks"
                                              TickPlacement="Outside"
                                              ValueChanged="BackdropSlider_ValueChanged" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- PDF Tools View -->
                <pdf:PdfToolsView x:Name="PdfToolsView"
                                  Visibility="Collapsed"
                                  RenderTransformOrigin="0.5,0.5"
                                  ToolRequested="PdfToolsView_ToolRequested">
                    <pdf:PdfToolsView.RenderTransform>
                        <CompositeTransform x:Name="PdfToolsTransform"/>
                    </pdf:PdfToolsView.RenderTransform>
                </pdf:PdfToolsView>

                <!-- Unified Conversion Detail View -->
                <pdf:ConversionDetailView x:Name="ConversionDetailView"
                                         Visibility="Collapsed"
                                         RenderTransformOrigin="0.5,0.5"
                                         BackRequested="ConversionDetailView_BackRequested">
                    <pdf:ConversionDetailView.RenderTransform>
                        <CompositeTransform/>
                    </pdf:ConversionDetailView.RenderTransform>
                </pdf:ConversionDetailView>
            </Grid>
        </NavigationView>

        <!-- Splash Screen Overlay -->
        <Grid x:Name="SplashOverlay" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Grid.RowSpan="2" Canvas.ZIndex="9999" Loaded="SplashOverlay_Loaded">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                <TextBlock x:Name="SplashLogo" Text="Eezy Pro" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="SplashLogoTransform" Y="20"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
